              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "posts", "{postId}", "comments"]
            }
          }
        },
        {
          "name": "Add Bot Reply",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Nice post!\",\n  \"parentCommentId\": 1\n}",
